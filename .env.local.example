# Copy to .env.local for local development.

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback

# Browser calls this base for dashboard API (usually the Next.js proxy).
NEXT_PUBLIC_API_URL=/api/bot

# Server-side: Python FastAPI (or public URL in production). Used by the home page and verification route.
API_PROXY_TARGET=http://127.0.0.1:8000

# Optional: override where /api/bot proxies (comma or space separated fallbacks). Defaults to API_PROXY_TARGET or 127.0.0.1:8000.
# BOT_API_URL=http://127.0.0.1:8000

# BOT_API_TIMEOUT_MS=45000
# BOT_API_VERIFY_TIMEOUT_MS=90000
